# Copy this file to `.env` and fill in values. `.env` is gitignored.
#   cp .env.example .env

# Secret used to sign session cookies. Use a long random string.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Port for local `npm start` (optional, defaults to 3000).
PORT=3000

# Hosted libSQL / Turso database (used in production).
# If both are left blank, the app falls back to a local SQLite file (urls.db).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Public origin used to build short links, e.g. https://theurlshortner.com
# If blank, the app uses the incoming request host.
BASE_URL=
